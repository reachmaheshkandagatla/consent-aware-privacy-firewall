{
  "manifest_version": 3,
  "name": "Consent-Aware Privacy Firewall",
  "description": "Locally scans ChatGPT prompts for sensitive data and consent, providing inline protections.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Consent-Aware Privacy Firewall"
  },
  "options_ui": {
    "page": "dashboard/dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/detector.js",
        "src/masker.js",
        "src/storage.js",
        "src/attachment_scanner.js",
        "src/floating_icon.js",
        "src/inline_panel.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icon.svg", "dashboard/dashboard.html", "dashboard/dashboard.js", "dashboard/dashboard.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
